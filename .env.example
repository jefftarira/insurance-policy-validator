# Google AI Studio (Gemini) — required for the agent to run
# Get one at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Brevo SMTP (transactional email) — required for actual email delivery
# Free tier: 300 emails/day. Get credentials at: https://app.brevo.com → SMTP & API → SMTP tab
# If unset, send_notifications will warn but not fail the agent run.
BREVO_SMTP_USER=
BREVO_SMTP_PASS=

# From address shown in the email. Must be a verified Sender in Brevo
# (your Brevo login email is auto-verified; others require email confirmation).
# Format: "Display Name <email@domain.com>" or just "email@domain.com"
EMAIL_FROM=

# Optional: override Brevo SMTP host/port.
# Defaults: smtp-relay.sendinblue.com:587 (STARTTLS).
# Use port 465 for SSL. The .sendinblue.com hostname is preferred — its TLS cert
# does not match smtp-relay.brevo.com in some regions (e.g. South America).
# BREVO_SMTP_HOST=smtp-relay.sendinblue.com
# BREVO_SMTP_PORT=587

# Optional: override Gemini model. Default: gemini-2.5-flash
# Fallback for higher daily quota (slower per request): gemini-3.1-flash-lite
# GEMINI_MODEL_OVERRIDE=gemini-3.1-flash-lite
# GEMINI_USE_FALLBACK=1
